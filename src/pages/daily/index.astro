---
// Standalone page for the Daily app. Lives under jordanmoreno.me/daily but is
// intentionally its own thing — no site header, no links back to the personal site.
const appStoreUrl = 'https://apps.apple.com/us/app/daily-private-journal/id6761246834';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daily — Private Journal</title>
  <meta name="description" content="Daily: Your private, minimalist, everyday journal. Write one entry a day, keep track of your entries over time.">
  <meta property="og:title" content="Daily — Private Journal">
  <meta property="og:description" content="The most minimal everyday journal on your phone.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://jordanmoreno.me/daily">
  <meta property="og:image" content="https://jordanmoreno.me/assets/daily-icon.png">
  <link rel="icon" type="image/png" href="/assets/daily-icon.png">
  <link rel="apple-touch-icon" href="/assets/daily-icon.png">
</head>
<body>
  <main class="page">
    <h1 class="wordmark">Daily</h1>

    <p class="headline">The most minimal everyday&nbsp;journal on your&nbsp;phone</p>

    <div class="phone" role="img" aria-label="iPhone showing the Daily app icon on a black screen">
      <div class="phone-screen">
        <span class="phone-island" aria-hidden="true"></span>
        <img src="/assets/daily-icon.png" alt="" class="phone-icon" width="96" height="96" loading="lazy">
      </div>
    </div>

    <a href={appStoreUrl} class="store-badge" target="_blank" rel="noopener">
      <img
        src="https://tools.applemediaservices.com/api/badges/download-on-the-app-store/black/en-us?size=250x83"
        alt="Download on the App Store"
        width="200"
        height="67"
        loading="lazy"
      />
    </a>
  </main>

  <footer class="footer">
    <span>&copy; <span id="year"></span> Jordan Moreno</span>
    <a href="/daily/privacypolicy">Privacy Policy</a>
  </footer>

  <script>
    document.getElementById('year').textContent = new Date().getFullYear().toString();
  </script>
</body>
</html>

<style>
  @font-face {
    font-family: 'Playwrite IE';
    src: url('/assets/fonts/PlaywriteIE-Regular.ttf') format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :global(*) { box-sizing: border-box; margin: 0; padding: 0; }

  :global(html), :global(body) {
    background: #000;
    min-height: 100vh;
  }

  body {
    color: #f2ede0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .page {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: clamp(56px, 10vh, 110px) 24px 48px;
  }

  .wordmark {
    font-family: 'Playwrite IE', 'Snell Roundhand', cursive;
    font-weight: 400;
    font-size: clamp(36px, 7vw, 52px);
    line-height: 1.5;
  }

  .headline {
    margin: 28px auto 0;
    max-width: 480px;
    font-size: clamp(26px, 5.4vw, 38px);
    font-weight: 700;
    line-height: 1.22;
    letter-spacing: -0.015em;
    color: #ffffff;
  }

  /* Phone mockup — recreated from the App Store marketing shot */
  .phone {
    margin-top: 56px;
    width: min(300px, 78vw);
    aspect-ratio: 300 / 610;
    border-radius: 48px;
    padding: 10px;
    background: linear-gradient(160deg, #3d3d40, #1c1c1e 45%, #2a2a2d);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 30px 80px rgba(0, 0, 0, 0.8);
  }

  .phone-screen {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 38px;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .phone-island {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 86px;
    height: 24px;
    border-radius: 999px;
    background: #17171a;
  }

  .phone-icon {
    width: 96px;
    height: 96px;
    border-radius: 22px;
  }

  .store-badge {
    display: inline-block;
    margin-top: 56px;
  }

  .store-badge img {
    display: block;
    width: 200px;
    height: auto;
  }

  .footer {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    padding: 24px 24px 40px;
    font-size: 13px;
    color: rgba(242, 237, 224, 0.55);
  }

  .footer a {
    color: rgba(242, 237, 224, 0.55);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer a:hover,
  .footer a:focus-visible {
    color: #f2ede0;
  }

  .footer a:focus-visible {
    outline: 2px solid rgba(242, 237, 224, 0.55);
    outline-offset: 3px;
  }
</style>
