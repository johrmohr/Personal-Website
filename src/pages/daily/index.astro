---
import '../../styles/site.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daily - Jordan Moreno</title>
  <link rel="icon" type="image/png" href="/Blackhole.png">
</head>
<body class="plain-page-body">
  <header class="site-header">
    <div class="site-header-leading">
      <a href="/" class="brand brand--static" aria-label="Jordan Moreno">Jordan Moreno</a>
    </div>
    <div class="site-header-trailing">
      <a href="/daily" class="header-link" aria-current="page">Daily</a>
      <a href="/blog" class="header-link">Blog</a>
    </div>
  </header>

  <main class="news2me-page">
    <section class="news2me-section news2me-section--hero" aria-label="Daily page hero">
      <div class="news2me-shell">
        <div class="news2me-hero-grid">
          <div class="news2me-hero-titleblock">
            <div class="news2me-date-row">
              <div class="news2me-mark" aria-hidden="true">
                <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="8" y="8" width="56" height="56" rx="12" stroke="currentColor" stroke-width="5"/>
                  <rect x="14" y="14" width="44" height="44" rx="8" fill="currentColor"/>
                  <rect x="20" y="20" width="7" height="7" rx="1.5" fill="var(--color-bg, #000)"/>
                  <rect x="32.5" y="20" width="7" height="7" rx="1.5" fill="var(--color-bg, #000)"/>
                  <rect x="45" y="20" width="7" height="7" rx="1.5" fill="var(--color-bg, #000)"/>
                  <rect x="20" y="32.5" width="7" height="7" rx="1.5" fill="var(--color-bg, #000)"/>
                  <rect x="32.5" y="32.5" width="7" height="7" rx="1.5" fill="var(--color-bg, #000)"/>
                  <rect x="45" y="32.5" width="7" height="7" rx="1.5" fill="var(--color-bg, #000)"/>
                  <rect x="20" y="45" width="7" height="7" rx="1.5" fill="var(--color-bg, #000)"/>
                  <rect x="32.5" y="45" width="7" height="7" rx="1.5" fill="var(--color-bg, #000)"/>
                  <rect x="45" y="45" width="7" height="7" rx="1.5" fill="var(--color-bg, #000)"/>
                </svg>
              </div>
              <h1 class="news2me-date" id="news2me-current-date">March 9, 2026</h1>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="news2me-section news2me-section--framed" aria-labelledby="news2me-feature-title">
      <div class="news2me-shell">
        <div class="news2me-divider" aria-hidden="true"></div>
      </div>
      <div class="news2me-shell">
        <div class="news2me-feature-grid">
          <div class="news2me-feature-copy">
            <div class="news2me-feature-header">
              <span class="news2me-feature-label">Economic Index</span>
              <h2 id="news2me-feature-title" class="news2me-feature-title">
                Analyzing how Claude is used across the economy.
              </h2>
            </div>
            <div class="news2me-feature-footer">
              <p class="news2me-feature-text">
                The Anthropic Economic Index reveals the shape of AI adoption across the world.
                Here, you can explore the data behind our research to understand how people are
                using Claude across every US state and hundreds of occupations.
              </p>
              <a href="https://www.anthropic.com/economic-index" class="news2me-cta" target="_blank" rel="noopener">
                <span>Read more</span>
                <span class="news2me-cta-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4.14585 9.87492L14.4584 9.87492L9.60419 5.04158L10.5 4.14575L16.8542 10.4999L10.5 16.8541L9.60419 15.9583L14.4584 11.1249L4.14585 11.1249L4.14585 9.87492Z" fill="currentColor"></path>
                  </svg>
                </span>
              </a>
            </div>
          </div>

          <div class="news2me-feature-media">
            <figure class="news2me-feature-image">
              <img
                src="https://www-cdn.anthropic.com/images/4zrzovbb/website/1e2cc2ea6907317ec1daf171d8a8889c170fc727-1600x900.png"
                alt="Analyzing how Claude is used across the economy."
                loading="lazy"
              />
            </figure>
          </div>
        </div>
      </div>
    </section>

    <section class="news2me-section news2me-section--framed" aria-labelledby="news2me-updates-title">
      <div class="news2me-shell">
        <div class="news2me-divider" aria-hidden="true"></div>
      </div>
      <div class="news2me-shell">
        <div class="news2me-updates-header">
          <h2 id="news2me-updates-title" class="news2me-section-title">Latest updates</h2>
          <label class="news2me-search" for="news2me-search-input">
            <span class="news2me-search-sr">Search</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M8.5 2C12.0899 2 15 4.91015 15 8.5C15 10.1149 14.4094 11.5908 13.4346 12.7275L17.8535 17.1465L17.918 17.2246C18.0461 17.4187 18.0244 17.6827 17.8535 17.8535C17.6827 18.0244 17.4187 18.0461 17.2246 17.918L17.1465 17.8535L12.7275 13.4346C11.5908 14.4094 10.1149 15 8.5 15C4.91015 15 2 12.0899 2 8.5C2 4.91015 4.91015 2 8.5 2ZM8.5 3C5.46243 3 3 5.46243 3 8.5C3 11.5376 5.46243 14 8.5 14C11.5376 14 14 11.5376 14 8.5C14 5.46243 11.5376 3 8.5 3Z" fill="currentColor"></path>
            </svg>
            <input id="news2me-search-input" type="text" placeholder="Search" aria-label="Search" />
          </label>
        </div>

        <div class="news2me-updates-grid">
          <div class="news2me-updates-main">
            <div class="news2me-update-head" aria-hidden="true">
              <span>Date</span>
              <span>Category</span>
              <span>Title</span>
            </div>

            <ul class="news2me-update-list">
              <li>
                <a href="https://www.anthropic.com/research/economic-index-primitives" class="news2me-update-link" target="_blank" rel="noopener">
                  <div class="news2me-update-meta">
                    <time class="news2me-update-time">Jan 15, 2026</time>
                    <span class="news2me-update-category">Economic Research</span>
                  </div>
                  <span class="news2me-update-title">Anthropic Economic Index: New building blocks for understanding AI use</span>
                </a>
              </li>
              <li>
                <a href="https://www.anthropic.com/research/anthropic-economic-index-january-2026-report" class="news2me-update-link" target="_blank" rel="noopener">
                  <div class="news2me-update-meta">
                    <time class="news2me-update-time">Jan 15, 2026</time>
                    <span class="news2me-update-category">Economic Research</span>
                  </div>
                  <span class="news2me-update-title">Anthropic Economic Index report: economic primitives</span>
                </a>
              </li>
              <li>
                <a href="https://www.anthropic.com/news/economic-futures-uk-europe" class="news2me-update-link" target="_blank" rel="noopener">
                  <div class="news2me-update-meta">
                    <time class="news2me-update-time">Nov 5, 2025</time>
                    <span class="news2me-update-category">Economic Research</span>
                  </div>
                  <span class="news2me-update-title">Launching the Anthropic Economic Futures Programme in the UK and Europe</span>
                </a>
              </li>
              <li>
                <a href="https://www.anthropic.com/research/anthropic-economic-index-september-2025-report" class="news2me-update-link" target="_blank" rel="noopener">
                  <div class="news2me-update-meta">
                    <time class="news2me-update-time">Sep 15, 2025</time>
                    <span class="news2me-update-category">Economic Research</span>
                  </div>
                  <span class="news2me-update-title">Anthropic Economic Index report: Uneven geographic and enterprise AI adoption</span>
                </a>
              </li>
              <li>
                <a href="https://www.anthropic.com/research/economic-index-geography" class="news2me-update-link" target="_blank" rel="noopener">
                  <div class="news2me-update-meta">
                    <time class="news2me-update-time">Sep 15, 2025</time>
                    <span class="news2me-update-category">Economic Research</span>
                  </div>
                  <span class="news2me-update-title">Anthropic Economic Index: Tracking AI’s role in the US and global economy</span>
                </a>
              </li>
              <li>
                <a href="https://www.anthropic.com/research/impact-software-development" class="news2me-update-link" target="_blank" rel="noopener">
                  <div class="news2me-update-meta">
                    <time class="news2me-update-time">Apr 28, 2025</time>
                    <span class="news2me-update-category">Societal Impacts</span>
                  </div>
                  <span class="news2me-update-title">Anthropic Economic Index: AI’s impact on software development</span>
                </a>
              </li>
              <li>
                <a href="https://www.anthropic.com/news/anthropic-economic-index-insights-from-claude-sonnet-3-7" class="news2me-update-link" target="_blank" rel="noopener">
                  <div class="news2me-update-meta">
                    <time class="news2me-update-time">Mar 27, 2025</time>
                    <span class="news2me-update-category">Societal Impacts</span>
                  </div>
                  <span class="news2me-update-title">Anthropic Economic Index: Insights from Claude 3.7 Sonnet</span>
                </a>
              </li>
              <li>
                <a href="https://www.anthropic.com/news/the-anthropic-economic-index" class="news2me-update-link" target="_blank" rel="noopener">
                  <div class="news2me-update-meta">
                    <time class="news2me-update-time">Feb 10, 2025</time>
                    <span class="news2me-update-category">Societal Impacts</span>
                  </div>
                  <span class="news2me-update-title">The Anthropic Economic Index</span>
                </a>
              </li>
            </ul>
          </div>

          <aside class="news2me-updates-aside" aria-hidden="true">
            <div class="news2me-updates-illustration">
              <img
                src="https://www-cdn.anthropic.com/images/4zrzovbb/website/1576ae23eaf481f33bd36ab468171cc69d12361a-1000x1000.svg"
                alt="Anthropic Economic Index: New building blocks for understanding AI use"
                loading="lazy"
              />
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="news2me-section news2me-section--announcements" aria-labelledby="news2me-announcements-title">
      <div class="news2me-shell">
        <div class="news2me-announcements-intro">
          <h2 id="news2me-announcements-title" class="news2me-section-title">Announcements</h2>
        </div>

        <div class="news2me-announcement-grid">
          <article class="news2me-announcement-item">
            <h3 class="news2me-announcement-title">Economic Futures Symposium Proposals</h3>
            <p class="news2me-announcement-copy">A selection of policy proposals from attendees at our DC Economic Futures Symposium</p>
            <a href="https://www.anthropic.com/economic-futures/symposium-proposals" class="news2me-inline-link" target="_blank" rel="noopener">Read more</a>
          </article>

          <article class="news2me-announcement-item">
            <h3 class="news2me-announcement-title">Introducing Anthropic Economic Futures Program</h3>
            <p class="news2me-announcement-copy">We’re launching the Anthropic Economic Futures program, a multidisciplinary effort that builds upon our existing economic research efforts.</p>
            <a href="https://www.anthropic.com/economic-futures/program" class="news2me-inline-link" target="_blank" rel="noopener">Read more</a>
          </article>

          <article class="news2me-announcement-item">
            <h3 class="news2me-announcement-title">Preserving privacy</h3>
            <p class="news2me-announcement-copy">The Anthropic Economic Index is made possible by Clio, a system that allows us to analyze conversations with Claude while preserving user privacy.</p>
            <a href="https://www.anthropic.com/news/clio" class="news2me-inline-link" target="_blank" rel="noopener">Read more</a>
          </article>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer plain-page-footer">
    <a href="/daily/privacypolicy" class="footer-privacy-link">Privacy Policy</a>
    <span class="footer-copy">&copy; <span id="year"></span></span>
    <div class="footer-icons" aria-label="Social links">
      <a href="https://github.com/johrmohr" target="_blank" rel="noopener" aria-label="GitHub" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6.48 2 2 6.58 2 12.26c0 4.52 2.87 8.35 6.84 9.7.5.09.68-.22.68-.48 0-.24-.01-.88-.01-1.73-2.78.61-3.37-1.2-3.37-1.2-.45-1.17-1.11-1.48-1.11-1.48-.91-.64.07-.63.07-.63 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.27 2.75 1.05.8-.23 1.65-.35 2.5-.35s1.7.12 2.5.35c1.91-1.32 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.95-2.34 4.81-4.57 5.06.36.32.67.94.67 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.58.69.48A10.05 10.05 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/in/jordan-moreno-" target="_blank" rel="noopener" aria-label="LinkedIn" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6.94 7.5c0 .91-.73 1.65-1.64 1.65-.9 0-1.64-.74-1.64-1.65 0-.9.74-1.64 1.64-1.64.91 0 1.64.74 1.64 1.64ZM3.99 20.5h2.62V9.5H3.99v11Zm6.23-11h-2.6v11h2.6v-6.13c0-1.61.31-3.17 2.29-3.17 1.96 0 1.99 1.83 1.99 3.26v6.04h2.62v-6.83c0-3.37-.73-5.97-4.39-5.97-1.78 0-2.97.98-3.47 1.91h-.04v-1.61Z" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://x.com/johrmohr" target="_blank" rel="noopener" aria-label="X" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="currentColor"/>
        </svg>
      </a>
      <a href="mailto:3moreno.jordan@gmail.com" aria-label="Email" class="icon-link">
