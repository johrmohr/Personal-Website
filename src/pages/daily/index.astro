          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" fill="none"/>
          <polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="2" fill="none"/>
        </svg>
      </a>
    </div>
  </footer>

  <script>
    const now = new Date();
    document.getElementById('year').textContent = now.getFullYear().toString();

    const dateTarget = document.getElementById('news2me-current-date');
    const dateFormatter = new Intl.DateTimeFormat('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    });

    const updateCurrentDate = () => {
      if (!dateTarget) return;
      const current = new Date();
      dateTarget.textContent = dateFormatter.format(current);
    };

    updateCurrentDate();

    const scheduleDateRefresh = () => {
      const current = new Date();
      const nextMidnight = new Date(current);
      nextMidnight.setHours(24, 0, 0, 0);
      window.setTimeout(() => {
        updateCurrentDate();
        scheduleDateRefresh();
      }, nextMidnight.getTime() - current.getTime());
    };

    scheduleDateRefresh();
  </script>
</body>
</html>
