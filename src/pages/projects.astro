---
import '../styles/site.css';

const projects = [
  {
    title: "Accentuate",
    description: "Full-stack iOS app for language learning. Built with Swift and Firebase, featuring AI-powered pronunciation feedback and personalized learning paths.",
    github: "https://github.com/johrmohr",
    link: "#",
    image: "/assets/accentuate-preview.png"
  },
  {
    title: "Cell Migration Research",
    description: "Computational analysis of fiber alignment's influence on cell migration patterns. Used Python and MATLAB for image processing and statistical modeling.",
    github: "https://github.com/johrmohr",
    link: "/assets/Research%20Poster.pdf",
    image: "/assets/research-preview.png"
  },
  {
    title: "3motion Labs Projects",
    description: "Software engineering work on motion capture and 3D modeling tools. Building next-generation creative tools for artists and designers.",
    github: "https://github.com/johrmohr",
    link: "https://3motion.io",
    image: "/assets/3motion-preview.png"
  }
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Projects - Jordan Moreno</title>
  <link rel="icon" type="image/png" href="/Blackhole.png">
</head>
<body>
  <header class="site-header">
    <a href="/" class="brand brand--static">Jordan Moreno</a>
    <nav class="nav">
      <a href="/#about">about</a>
      <a href="/projects" class="active">projects</a>
      <a href="/#experience">experience</a>
      <a href="/#research">research</a>
    </nav>
  </header>

  <main class="projects-page">
    <div class="search-bar">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
        <path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <input type="text" placeholder="search for a project, technology, etc." id="project-search" />
    </div>

    <div class="projects-grid">
      {projects.map((project) => (
        <article class="project-card">
          <div class="project-image">
            <div class="project-image-placeholder">
              <span>{project.title.charAt(0)}</span>
            </div>
          </div>
          <div class="project-content">
            <div class="project-header">
              <h2 class="project-title">{project.title}</h2>
              <div class="project-links">
                <a href={project.github} target="_blank" rel="noopener" aria-label="GitHub">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2C6.48 2 2 6.58 2 12.26c0 4.52 2.87 8.35 6.84 9.7.5.09.68-.22.68-.48 0-.24-.01-.88-.01-1.73-2.78.61-3.37-1.2-3.37-1.2-.45-1.17-1.11-1.48-1.11-1.48-.91-.64.07-.63.07-.63 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.27 2.75 1.05.8-.23 1.65-.35 2.5-.35s1.7.12 2.5.35c1.91-1.32 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.95-2.34 4.81-4.57 5.06.36.32.67.94.67 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.58.69.48A10.05 10.05 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z" fill="currentColor"/>
                  </svg>
                </a>
                <a href={project.link} target="_blank" rel="noopener" aria-label="External link">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="15,3 21,3 21,9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="10" y1="14" x2="21" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            </div>
            <p class="project-description">{project.description}</p>
          </div>
        </article>
      ))}
    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-icons" aria-label="Social links">
      <a href="https://github.com/johrmohr" target="_blank" rel="noopener" aria-label="GitHub" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6.48 2 2 6.58 2 12.26c0 4.52 2.87 8.35 6.84 9.7.5.09.68-.22.68-.48 0-.24-.01-.88-.01-1.73-2.78.61-3.37-1.2-3.37-1.2-.45-1.17-1.11-1.48-1.11-1.48-.91-.64.07-.63.07-.63 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.27 2.75 1.05.8-.23 1.65-.35 2.5-.35s1.7.12 2.5.35c1.91-1.32 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.95-2.34 4.81-4.57 5.06.36.32.67.94.67 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.58.69.48A10.05 10.05 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/in/jordan-moreno-" target="_blank" rel="noopener" aria-label="LinkedIn" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6.94 7.5c0 .91-.73 1.65-1.64 1.65-.9 0-1.64-.74-1.64-1.65 0-.9.74-1.64 1.64-1.64.91 0 1.64.74 1.64 1.64ZM3.99 20.5h2.62V9.5H3.99v11Zm6.23-11h-2.6v11h2.6v-6.13c0-1.61.31-3.17 2.29-3.17 1.96 0 1.99 1.83 1.99 3.26v6.04h2.62v-6.83c0-3.37-.73-5.97-4.39-5.97-1.78 0-2.97.98-3.47 1.91h-.04v-1.61Z" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://x.com/johrmohr" target="_blank" rel="noopener" aria-label="X" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="currentColor"/>
        </svg>
      </a>
      <a href="mailto:3moreno.jordan@gmail.com" aria-label="Email" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" fill="none"/>
          <polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="2" fill="none"/>
        </svg>
      </a>
    </div>
    <span>&copy; <span id="year"></span> Jordan Moreno</span>
    <a href="/" class="footer-link">back to home</a>
  </footer>

  <script>
    document.getElementById('year').textContent = new Date().getFullYear().toString();
    // Simple search filter
    const searchInput = document.getElementById('project-search');
    const cards = document.querySelectorAll('.project-card');

    searchInput?.addEventListener('input', (e) => {
      const query = e.target instanceof HTMLInputElement ? e.target.value.toLowerCase() : '';
      cards.forEach(card => {
        const text = card.textContent?.toLowerCase() || '';
        if (card instanceof HTMLElement) {
          card.style.display = text.includes(query) ? '' : 'none';
        }
      });
    });
  </script>
</body>
</html>
