  <script>
    document.getElementById('year').textContent = new Date().getFullYear().toString();
    const brand = document.querySelector('.brand--home');
    const introCopy = brand?.querySelector('.brand-intro-copy');
    const surnameMeasure = brand?.querySelector('.brand-measure--surname');
    const hero = document.querySelector('.hero');
    const heroRevealCopy = document.querySelector('.hero-reveal-copy');
    const blackholeLink = document.querySelector('.blackhole-link');
    const sameOriginReferrer = (() => {
      try {
        const referrerUrl = new URL(document.referrer);
        return referrerUrl.origin === window.location.origin ? referrerUrl : null;
      } catch {
        return null;
      }
    })();
    const shouldAnimateHomeReturn = Boolean(
      sameOriginReferrer &&
      sameOriginReferrer.pathname !== '/' &&
      sameOriginReferrer.pathname !== '/index.html'
    );
    const MOBILE_BREAKPOINT = 768;
    const TOP_RESET_THRESHOLD = 2;
    const COLLAPSE_SCROLL_THRESHOLD = 12;
    const MOBILE_IDLE_SCROLL_LIMIT = 72;
    let introWidth = 0;
    let surnameWidth = 0;
    let ticking = false;
    let userHasScrolled = false;
    let heroRevealSuckDeltaX = 0;
    let heroRevealSuckDeltaY = 0;
    let heroRevealSuckDistance = 1;
    let heroRevealTriggered = false;
    let brandInitialized = false;

    const getScrollY = () => Math.max(
      window.scrollY,
      document.documentElement.scrollTop,
      document.body.scrollTop,
      0
    );

    const isMobileViewport = () => window.innerWidth <= MOBILE_BREAKPOINT;

    const setBrandState = (nextState) => {
      if (brand?.dataset.brandState !== nextState) {
        brand.dataset.brandState = nextState;
      }
    };

    const updateBrand = () => {
      if (!brand) {
        return;
      }

      const currentScrollY = getScrollY();

      if (currentScrollY <= TOP_RESET_THRESHOLD) {
        setBrandState('expanded');
        ticking = false;
        return;
      }

      if (isMobileViewport() && !userHasScrolled && currentScrollY <= MOBILE_IDLE_SCROLL_LIMIT) {
        setBrandState('expanded');
        ticking = false;
        return;
      }

      setBrandState(currentScrollY > COLLAPSE_SCROLL_THRESHOLD ? 'collapsed' : 'expanded');
      ticking = false;
    };

    const measureBrand = () => {
      if (!brand || !introCopy || !surnameMeasure) {
        return;
      }

      introWidth = introCopy.getBoundingClientRect().width;
      surnameWidth = surnameMeasure.getBoundingClientRect().width;
      brand.style.setProperty('--brand-intro-full-width', `${introWidth}px`);
      brand.style.setProperty('--brand-surname-full-width', `${surnameWidth}px`);
      
      if (!brandInitialized) {
        brandInitialized = true;
        brand.dataset.brandState = shouldAnimateHomeReturn ? 'collapsed' : 'expanded';
        brand.dataset.brandReady = 'true';

        window.requestAnimationFrame(() => {
          brand.dataset.brandAnimate = 'true';

          if (shouldAnimateHomeReturn) {
            window.requestAnimationFrame(() => {
              setBrandState('expanded');
            });
          } else {
            updateBrand();
          }
        });

        return;
      }

      updateBrand();
    };

    const scheduleBrandUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateBrand);
        ticking = true;
      }
    };

    const markUserScrollIntent = () => {
      userHasScrolled = true;
    };

    const revealHeroCopy = () => {
      if (!heroRevealCopy || heroRevealTriggered) {
        return;
      }

      heroRevealTriggered = true;

      window.requestAnimationFrame(() => {
        window.setTimeout(() => {
          heroRevealCopy.dataset.revealState = 'visible';
        }, 140);
      });
    };

    const handleViewportChange = () => {
      measureBrand();
      measureHeroRevealSuction();
    };

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    const setHeroRevealScrollState = (progress) => {
      if (!heroRevealCopy) {
        return;
      }

      const eased = 1 - Math.pow(1 - progress, 2.1);
      const scale = 1 - (0.86 * eased);
      const opacity = progress >= 0.96 ? 0 : Math.max(0, 1 - (0.96 * eased));
      const blur = 3.2 * eased;

      heroRevealCopy.style.setProperty('--copy-scroll-x', `${heroRevealSuckDeltaX * eased}px`);
      heroRevealCopy.style.setProperty('--copy-scroll-y', `${heroRevealSuckDeltaY * eased}px`);
      heroRevealCopy.style.setProperty('--copy-scroll-scale', `${scale}`);
      heroRevealCopy.style.setProperty('--copy-scroll-opacity', `${opacity}`);
      heroRevealCopy.style.setProperty('--copy-scroll-blur', `${blur}px`);
    };

    const updateHeroRevealSuction = () => {
      if (!hero) {
        return;
      }

      const heroTop = hero.getBoundingClientRect().top + window.scrollY;
      const scrollWithinHero = Math.max(0, window.scrollY - heroTop);
      const progress = clamp(scrollWithinHero / heroRevealSuckDistance, 0, 1);

      setHeroRevealScrollState(progress);
    };

    const measureHeroRevealSuction = () => {
      if (!hero || !blackholeLink || !heroRevealCopy) {
        return;
      }

      setHeroRevealScrollState(0);

      const heroRect = hero.getBoundingClientRect();
      const blackholeRect = blackholeLink.getBoundingClientRect();
      const heroRevealRect = heroRevealCopy.getBoundingClientRect();
      const blackholeCenterX = blackholeRect.left + (blackholeRect.width / 2) - heroRect.left;
      const blackholeCenterY = blackholeRect.top + (blackholeRect.height / 2) - heroRect.top;
      const blackholeTop = blackholeRect.top - heroRect.top;
      const heroRevealCenterX = heroRevealRect.left + (heroRevealRect.width / 2) - heroRect.left;
      const heroRevealCenterY = heroRevealRect.top + (heroRevealRect.height / 2) - heroRect.top;
      const heroRevealBottom = heroRevealRect.bottom - heroRect.top;

      heroRevealSuckDeltaX = blackholeCenterX - heroRevealCenterX;
      heroRevealSuckDeltaY = blackholeCenterY - heroRevealCenterY;
      heroRevealSuckDistance = Math.max(180, blackholeTop - heroRevealBottom);

      updateHeroRevealSuction();
    };

    window.addEventListener('scroll', () => {
      if (getScrollY() <= TOP_RESET_THRESHOLD) {
        userHasScrolled = false;
      }

      scheduleBrandUpdate();
      updateHeroRevealSuction();
    }, { passive: true });
    window.addEventListener('resize', handleViewportChange);
    window.addEventListener('load', () => {
      measureBrand();
      measureHeroRevealSuction();
      revealHeroCopy();
    });
    window.addEventListener('pageshow', (event) => {
      measureBrand();
      measureHeroRevealSuction();
      revealHeroCopy();
    });
    window.addEventListener('touchmove', markUserScrollIntent, { passive: true });
    window.addEventListener('wheel', markUserScrollIntent, { passive: true });
    window.visualViewport?.addEventListener('resize', handleViewportChange);
    document.fonts?.ready?.then(() => {
      measureBrand();
      measureHeroRevealSuction();
    });
    window.setTimeout(() => {
      measureBrand();
      measureHeroRevealSuction();
    }, 180);
    measureHeroRevealSuction();
    measureBrand();
    revealHeroCopy();
  </script>
</body>
</html>
