---
import '../styles/site.css';
import VideoScrubber from '../components/VideoScrubber.astro';

const signatureVideoSrc = '/assets/signature.mp4';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-K9ZLGBC0SS"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-K9ZLGBC0SS');
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jordan Moreno</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
</head>
<body>
  <VideoScrubber />

  <header class="site-header site-header--home">
    <div class="site-header-leading">
      <a href="/" class="brand brand--home" aria-label="Jordan Moreno" data-brand-state="expanded" data-brand-ready="false" data-brand-animate="false">
        <span class="brand-home" aria-hidden="true"><span class="brand-intro"><span class="brand-intro-copy">hi, i'm</span></span><span class="brand-name">Jordan</span><span class="brand-surname"><span class="brand-surname-copy">Moreno</span></span><span class="brand-measure brand-measure--surname">Moreno</span></span>
      </a>
    </div>
    <div class="site-header-trailing">
      <a href="/daily" class="header-link">Daily</a>
      <a href="/blog" class="header-link">Blog</a>
    </div>
  </header>

  <!-- Hero section with ASCII black hole -->
  <section class="hero">
    <div class="hero-photo-stack hero-photo-stack--signature" aria-label="Signature animation" data-photo-stack>
      <button
        type="button"
        class="hero-photo-card hero-photo-card--signature"
        data-stack-card
        data-stack-index="0"
        aria-label="Replay signature animation"
      >
        <span class="hero-photo-card-frame hero-photo-card-frame--signature">
          <video
            src={signatureVideoSrc}
            class="hero-photo-image hero-signature-video"
            data-signature-video
            muted
            playsinline
            preload="auto"
            autoplay
            disablepictureinpicture
          >
          </video>
        </span>
      </button>
    </div>
    <div class="hero-reveal-copy" aria-label="Intro text" data-reveal-state="hidden">
      <p class="hero-reveal-line hero-reveal-line--lead">SWE @ UCI</p>
    </div>
    <a href="/assets/resume.pdf" target="_blank" class="blackhole-link"><pre class="ascii-blackhole">
                                       @%%%%#####%%%%@
                                 @@%@%**+=--:..::--++*#%@@@
                            %#%@#**-.                  .-=*#%%@
                          @%%%#+-.                        .:=*#@
                       @%@@%**:                              :=*#@
                   %@%%%%*+=              %**%%##%%.           .:+*%%@
                 @@@%%#*=:             +##:-=:===--@%*=          .:=*##@
               @@%%#*=-.            .=+* *@@@@@@@@@#:#%+           .:-+*#%%@
            ##*++-:                +.-.#%%@%%@@%%@@%@%:**               :-++**#%
        #*=-.                    -*:*:@@@@%@@@@@@@@@@@@=#+                 ..:-=++*
    %**+=:                      -%*= #%%@@@@@@@@@@@@@@@#:#                   ...:-==+*
 %%#*++=:                        +*  #@%%%@%%@@%%@@%@@%%:                      ...:-++**%
    %#*+==:.                                -:=+==:.                          .:-==++*
        ##*+=-:                                                           .:-==++*#
           %##***++==-.                                          ..---==++***#
                 @%%%#%#****+*+==.    :::----:-------:.   .:+******#%%%
                        %@%%@%%%%*     -*-::++=++-::..    :*%%%@@@@
                            %%%@@%#.        ++**=.       :#@@%@@@%
                                  @@@=                .+@@@
                                     @%*=.         -=#@@
                                       %@@%@@@@@@@%@@%
</pre></a>
    <div class="bio-content">
      <div class="bio-columns">
        <div class="bio-column">
          <p class="bio-header">currently:</p>
          <ul class="bio-sub">
            <li>student growth @ <a href="https://pplx.ai/jordan-moreno" target="_blank" class="bio-link">perplexity</a></li>
            <li>studying software engineering @ <a href="https://ics.uci.edu/" target="_blank" class="bio-link">uc irvine</a></li>
            <li>growing quantum computing @ <a href="https://www.qc-uci.club/" target="_blank" class="bio-link">uc irvine</a></li>
            <li>building @ <a href="https://accentuateai.app" target="_blank" class="bio-link">accentuate</a></li>
          </ul>
        </div>
        <div class="bio-column">
          <p class="bio-header">previously:</p>
          <ul class="bio-sub">
            <li>ai engineer @ <a href="https://www.lps.uci.edu/" target="_blank" class="bio-link">uci lps</a></li>
            <li>swe @ <a href="https://3motionlabs.com/" target="_blank" class="bio-link">3motion labs</a></li>
            <li>swe intern @ <a href="https://dph.sbcounty.gov/" target="_blank" class="bio-link">sbd public health</a></li>
            <li>director @ <a href="https://www.nmun.org/" target="_blank" class="bio-link">national model united nations</a></li>
            <li>computational physics research @ <a href="https://icqmb.ucr.edu/" target="_blank" class="bio-link">ucr</a></li>
            <li>physics, cs, math, soc @ <a href="https://www.rcc.edu/index.html" target="_blank" class="bio-link">rcc</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="projects-container">
    <h2 class="projects-title">projects</h2>
    <div class="projects-row">
      <a href="http://64.181.241.137:8000/" target="_blank" class="project-card">
        <img src="/assets/rag-preview.png" alt="RAG Preview" class="project-image" />
        <h3 class="project-title">Retrieval-Augmented Generation</h3>
      </a>

      <a href="https://accentuateai.app" target="_blank" class="project-card">
        <img src="/assets/accentuate-preview.png" alt="Accentuate Preview" class="project-image" />
        <h3 class="project-title">Accentuate</h3>
      </a>

      <a href="https://crewchat.ai" target="_blank" class="project-card">
        <img src="/assets/crewchat-preview.png" alt="CrewChat Preview" class="project-image" />
        <h3 class="project-title">CrewChat</h3>
      </a>
    </div>
  </div>

  <div class="page-nav">
    <a href="https://webring.lpnuci.com/?nav=prev&from=jordanmoreno.me" class="page-nav-link">&lt;</a>
    <a href="https://webring.lpnuci.com/" class="page-nav-logo-link">
      <img src="/assets/lpn-webring-logo.png" height="48" alt="LPN Webring" class="page-nav-logo">
    </a>
    <a href="https://webring.lpnuci.com/?nav=next&from=jordanmoreno.me" class="page-nav-link">&gt;</a>
  </div>

  <footer class="site-footer">
    <span class="footer-copy">&copy; <span id="year"></span></span>
    <div class="footer-icons" aria-label="Social links">
      <a href="https://github.com/johrmohr" target="_blank" rel="noopener" aria-label="GitHub" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6.48 2 2 6.58 2 12.26c0 4.52 2.87 8.35 6.84 9.7.5.09.68-.22.68-.48 0-.24-.01-.88-.01-1.73-2.78.61-3.37-1.2-3.37-1.2-.45-1.17-1.11-1.48-1.11-1.48-.91-.64.07-.63.07-.63 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.27 2.75 1.05.8-.23 1.65-.35 2.5-.35s1.7.12 2.5.35c1.91-1.32 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.95-2.34 4.81-4.57 5.06.36.32.67.94.67 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.58.69.48A10.05 10.05 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/in/jordan-moreno-" target="_blank" rel="noopener" aria-label="LinkedIn" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6.94 7.5c0 .91-.73 1.65-1.64 1.65-.9 0-1.64-.74-1.64-1.65 0-.9.74-1.64 1.64-1.64.91 0 1.64.74 1.64 1.64ZM3.99 20.5h2.62V9.5H3.99v11Zm6.23-11h-2.6v11h2.6v-6.13c0-1.61.31-3.17 2.29-3.17 1.96 0 1.99 1.83 1.99 3.26v6.04h2.62v-6.83c0-3.37-.73-5.97-4.39-5.97-1.78 0-2.97.98-3.47 1.91h-.04v-1.61Z" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://x.com/johrmohr" target="_blank" rel="noopener" aria-label="X" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="currentColor"/>
        </svg>
      </a>
      <a href="mailto:3moreno.jordan@gmail.com" aria-label="Email" class="icon-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" fill="none"/>
          <polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="2" fill="none"/>
        </svg>
      </a>
    </div>
  </footer>

  <script>
    document.getElementById('year').textContent = new Date().getFullYear().toString();
    const brand = document.querySelector('.brand--home');
    const introCopy = brand?.querySelector('.brand-intro-copy');
    const surnameMeasure = brand?.querySelector('.brand-measure--surname');
    const hero = document.querySelector('.hero');
    const heroRevealCopy = document.querySelector('.hero-reveal-copy');
    const photoStack = document.querySelector('[data-photo-stack]');
    const stackCards = photoStack ? Array.from(photoStack.querySelectorAll('[data-stack-card]')) : [];
    const signatureVideo = document.querySelector('[data-signature-video]');
    const blackholeLink = document.querySelector('.blackhole-link');
    const sameOriginReferrer = (() => {
      try {
        const referrerUrl = new URL(document.referrer);
        return referrerUrl.origin === window.location.origin ? referrerUrl : null;
      } catch {
        return null;
      }
    })();
    const shouldAnimateHomeReturn = Boolean(
      sameOriginReferrer &&
      sameOriginReferrer.pathname !== '/' &&
      sameOriginReferrer.pathname !== '/index.html'
    );
    const MOBILE_BREAKPOINT = 768;
    const TOP_RESET_THRESHOLD = 2;
    const COLLAPSE_SCROLL_THRESHOLD = 12;
    const MOBILE_IDLE_SCROLL_LIMIT = 72;
    let introWidth = 0;
    let surnameWidth = 0;
    let ticking = false;
    let userHasScrolled = false;
    const stackAnchorIndex = 0;
    let hoveredStackIndex = -1;
    let selectedStackIndex = -1;
    let stackSuckDeltaX = 0;
    let stackSuckDeltaY = 0;
    let stackSuckDistance = 1;
    let heroRevealSuckDeltaX = 0;
    let heroRevealSuckDeltaY = 0;
    let heroRevealTriggered = false;
    let brandInitialized = false;

    const getScrollY = () => Math.max(
      window.scrollY,
      document.documentElement.scrollTop,
      document.body.scrollTop,
      0
    );

    const isMobileViewport = () => window.innerWidth <= MOBILE_BREAKPOINT;

    const setBrandState = (nextState) => {
      if (brand?.dataset.brandState !== nextState) {
        brand.dataset.brandState = nextState;
      }
    };

    const updateBrand = () => {
      if (!brand) {
        return;
      }

      const currentScrollY = getScrollY();

      if (currentScrollY <= TOP_RESET_THRESHOLD) {
        setBrandState('expanded');
        ticking = false;
        return;
      }

      if (isMobileViewport() && !userHasScrolled && currentScrollY <= MOBILE_IDLE_SCROLL_LIMIT) {
        setBrandState('expanded');
        ticking = false;
        return;
      }

      setBrandState(currentScrollY > COLLAPSE_SCROLL_THRESHOLD ? 'collapsed' : 'expanded');
      ticking = false;
    };

    const measureBrand = () => {
      if (!brand || !introCopy || !surnameMeasure) {
        return;
      }

      introWidth = introCopy.getBoundingClientRect().width;
      surnameWidth = surnameMeasure.getBoundingClientRect().width;
      brand.style.setProperty('--brand-intro-full-width', `${introWidth}px`);
      brand.style.setProperty('--brand-surname-full-width', `${surnameWidth}px`);
      
      if (!brandInitialized) {
        brandInitialized = true;
        brand.dataset.brandState = shouldAnimateHomeReturn ? 'collapsed' : 'expanded';
        brand.dataset.brandReady = 'true';

        window.requestAnimationFrame(() => {
          brand.dataset.brandAnimate = 'true';

          if (shouldAnimateHomeReturn) {
            window.requestAnimationFrame(() => {
              setBrandState('expanded');
            });
          } else {
            updateBrand();
          }
        });

        return;
      }

      updateBrand();
    };

    const scheduleBrandUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateBrand);
        ticking = true;
      }
    };

    const markUserScrollIntent = () => {
      userHasScrolled = true;
    };

    const revealHeroCopy = () => {
      if (!heroRevealCopy || heroRevealTriggered) {
        return;
      }

      heroRevealTriggered = true;

      window.requestAnimationFrame(() => {
        window.setTimeout(() => {
          heroRevealCopy.dataset.revealState = 'visible';
        }, 140);
      });
    };

    const maybeAutoplaySignatureVideo = () => {
      if (!(signatureVideo instanceof HTMLVideoElement)) {
        return;
      }

      signatureVideo.muted = true;
      signatureVideo.defaultMuted = true;
      signatureVideo.playsInline = true;

      if (!signatureVideo.paused || signatureVideo.currentTime > 0) {
        return;
      }

      const playback = signatureVideo.play();

      if (playback && typeof playback.catch === 'function') {
        playback.catch(() => {});
      }
    };

    const replaySignatureVideo = () => {
      if (!(signatureVideo instanceof HTMLVideoElement)) {
        return;
      }

      signatureVideo.muted = true;
      signatureVideo.defaultMuted = true;
      signatureVideo.playsInline = true;

      const playFromStart = () => {
        signatureVideo.pause();

        try {
          signatureVideo.currentTime = 0;
        } catch {
          return;
        }

        const playback = signatureVideo.play();

        if (playback && typeof playback.catch === 'function') {
          playback.catch(() => {});
        }
      };

      if (signatureVideo.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA) {
        playFromStart();
        return;
      }

      signatureVideo.addEventListener('loadeddata', playFromStart, { once: true });
    };

    const handleViewportChange = () => {
      measureBrand();
      applyPhotoStackLayout();
      measurePhotoStackSuction();
    };

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    const setHeroRevealScrollState = (progress) => {
      if (!heroRevealCopy) {
        return;
      }

      const eased = 1 - Math.pow(1 - progress, 2.1);
      const scale = 1 - (0.86 * eased);
      const opacity = progress >= 0.96 ? 0 : Math.max(0, 1 - (0.96 * eased));
      const blur = 3.2 * eased;

      heroRevealCopy.style.setProperty('--copy-scroll-x', `${heroRevealSuckDeltaX * eased}px`);
      heroRevealCopy.style.setProperty('--copy-scroll-y', `${heroRevealSuckDeltaY * eased}px`);
      heroRevealCopy.style.setProperty('--copy-scroll-scale', `${scale}`);
      heroRevealCopy.style.setProperty('--copy-scroll-opacity', `${opacity}`);
      heroRevealCopy.style.setProperty('--copy-scroll-blur', `${blur}px`);
    };

    const setPhotoStackScrollState = (progress) => {
      if (!photoStack) {
        return;
      }

      const eased = 1 - Math.pow(1 - progress, 2.1);
      const scale = 1 - (0.86 * eased);
      const opacity = progress >= 0.96 ? 0 : Math.max(0, 1 - (0.96 * eased));
      const blur = 3.2 * eased;

      photoStack.style.setProperty('--stack-scroll-x', `${stackSuckDeltaX * eased}px`);
      photoStack.style.setProperty('--stack-scroll-y', `${stackSuckDeltaY * eased}px`);
      photoStack.style.setProperty('--stack-scroll-scale', `${scale}`);
      photoStack.style.setProperty('--stack-scroll-opacity', `${opacity}`);
      photoStack.style.setProperty('--stack-scroll-blur', `${blur}px`);
      photoStack.style.pointerEvents = progress >= 0.98 ? 'none' : '';
    };

    const updatePhotoStackSuction = () => {
      if (!photoStack || !hero) {
        return;
      }

      const heroTop = hero.getBoundingClientRect().top + window.scrollY;
      const scrollWithinHero = Math.max(0, window.scrollY - heroTop);
      const progress = clamp(scrollWithinHero / stackSuckDistance, 0, 1);

      setPhotoStackScrollState(progress);
      setHeroRevealScrollState(progress);
    };

    const measurePhotoStackSuction = () => {
      if (!photoStack || !hero || !blackholeLink) {
        return;
      }

      setPhotoStackScrollState(0);
      setHeroRevealScrollState(0);

      const heroRect = hero.getBoundingClientRect();
      const stackRect = photoStack.getBoundingClientRect();
      const blackholeRect = blackholeLink.getBoundingClientRect();
      const stackCenterX = stackRect.left + (stackRect.width / 2) - heroRect.left;
      const stackCenterY = stackRect.top + (stackRect.height / 2) - heroRect.top;
      const blackholeCenterX = blackholeRect.left + (blackholeRect.width / 2) - heroRect.left;
      const blackholeCenterY = blackholeRect.top + (blackholeRect.height / 2) - heroRect.top;
      const stackBottom = stackRect.bottom - heroRect.top;
      const blackholeTop = blackholeRect.top - heroRect.top;

      stackSuckDeltaX = blackholeCenterX - stackCenterX;
      stackSuckDeltaY = blackholeCenterY - stackCenterY;
      stackSuckDistance = Math.max(220, blackholeTop - stackBottom);

      if (heroRevealCopy) {
        const heroRevealRect = heroRevealCopy.getBoundingClientRect();
        const heroRevealCenterX = heroRevealRect.left + (heroRevealRect.width / 2) - heroRect.left;
        const heroRevealCenterY = heroRevealRect.top + (heroRevealRect.height / 2) - heroRect.top;

        heroRevealSuckDeltaX = blackholeCenterX - heroRevealCenterX;
        heroRevealSuckDeltaY = blackholeCenterY - heroRevealCenterY;
      }

      updatePhotoStackSuction();
    };

    const normalizeStackIndex = (value) => {
      if (!stackCards.length) {
        return 0;
      }

      return ((value % stackCards.length) + stackCards.length) % stackCards.length;
    };

    const getStackOffset = (cardIndex, anchorIndex) => {
      const forwardDistance = normalizeStackIndex(cardIndex - anchorIndex);

      if (forwardDistance === 0) {
        return 0;
      }

      if (forwardDistance <= stackCards.length / 2) {
        return forwardDistance;
      }

      return forwardDistance - stackCards.length;
    };

    const applyPhotoStackLayout = () => {
      if (!photoStack || !stackCards.length) {
        return;
      }

      const compactMultiplier = window.innerWidth <= MOBILE_BREAKPOINT ? 0.72 : window.innerWidth <= 1024 ? 0.86 : 1;
      const baseOffsets = stackCards.map((_, index) => getStackOffset(index, stackAnchorIndex));
      const hoveredOffset = hoveredStackIndex !== -1 ? baseOffsets[hoveredStackIndex] : null;

      stackCards.forEach((card, index) => {
        const offset = baseOffsets[index];
        const direction = offset === 0 ? 0 : Math.sign(offset);
        const distance = Math.abs(offset);
        let translateX = 0;
        let translateY = -4;
        let rotate = 0;
        let scale = 1;
        let opacity = 1;
        let brightness = 1;
        let saturate = 1;
        let zIndex = 30;
        let shadow = '0 28px 80px rgba(0, 0, 0, 0.38)';

        if (distance === 1) {
          translateX = direction * (108 * compactMultiplier);
          translateY = 14 * compactMultiplier;
          rotate = direction * 11;
          scale = 0.88;
          opacity = 0.92;
          brightness = 0.86;
          saturate = 0.92;
          zIndex = 20;
          shadow = '0 18px 48px rgba(0, 0, 0, 0.24)';
        } else if (distance >= 2) {
          const distanceBoost = distance - 2;
          translateX = direction * ((186 + distanceBoost * 44) * compactMultiplier);
          translateY = (30 + distanceBoost * 12) * compactMultiplier;
          rotate = direction * (17 + distanceBoost * 2);
          scale = Math.max(0.58, 0.72 - distanceBoost * 0.06);
          opacity = Math.max(0.28, 0.58 - distanceBoost * 0.08);
          brightness = Math.max(0.52, 0.66 - distanceBoost * 0.05);
          saturate = Math.max(0.6, 0.78 - distanceBoost * 0.05);
          zIndex = Math.max(8, 12 - distanceBoost);
          shadow = '0 14px 38px rgba(0, 0, 0, 0.2)';
        }

        if (hoveredStackIndex !== -1 && hoveredStackIndex !== index && hoveredOffset !== null && hoveredOffset !== 0) {
          const distanceFromHovered = Math.abs(offset - hoveredOffset);
          const hoverDepth = Math.max(1, distanceFromHovered);
          const rankedScale = Math.max(0.54, 0.92 - (hoverDepth - 1) * 0.1);
          const rankedOpacity = Math.max(0.26, 0.92 - (hoverDepth - 1) * 0.15);
          const rankedBrightness = Math.max(0.48, 0.9 - (hoverDepth - 1) * 0.08);
          const rankedSaturate = Math.max(0.58, 0.92 - (hoverDepth - 1) * 0.06);

          scale = rankedScale;
          opacity = rankedOpacity;
          brightness = rankedBrightness;
          saturate = rankedSaturate;
          zIndex = 30 - hoverDepth;
          shadow = hoverDepth === 1
            ? '0 20px 54px rgba(0, 0, 0, 0.26)'
            : `0 ${Math.max(10, 18 - hoverDepth * 2)}px ${Math.max(22, 44 - hoverDepth * 4)}px rgba(0, 0, 0, ${Math.max(0.14, 0.24 - hoverDepth * 0.02)})`;
        }

        if (hoveredStackIndex === index) {
          translateY -= 16 * compactMultiplier;
          scale += distance === 0 ? 0.08 : 0.14;
          opacity = 1;
          brightness = 1;
          saturate = 1.02;
          zIndex = 40;
          shadow = '0 36px 92px rgba(0, 0, 0, 0.42)';
        }

        card.style.setProperty('--card-x', `${translateX}px`);
        card.style.setProperty('--card-y', `${translateY}px`);
        card.style.setProperty('--card-rotate', `${rotate}deg`);
        card.style.setProperty('--card-scale', `${scale}`);
        card.style.setProperty('--card-opacity', `${opacity}`);
        card.style.setProperty('--card-brightness', `${brightness}`);
        card.style.setProperty('--card-saturate', `${saturate}`);
        card.style.setProperty('--card-z', `${zIndex}`);
        card.style.setProperty('--card-shadow', shadow);
        card.dataset.captionVisible = hoveredStackIndex === index && selectedStackIndex === index ? 'true' : 'false';
      });
    };

    stackCards.forEach((card, index) => {
      card.addEventListener('mouseenter', () => {
        hoveredStackIndex = index;
        applyPhotoStackLayout();
      });

      card.addEventListener('focus', () => {
        hoveredStackIndex = index;
        applyPhotoStackLayout();
      });

      card.addEventListener('mouseleave', () => {
        if (hoveredStackIndex === index) {
          hoveredStackIndex = -1;
          if (selectedStackIndex === index) {
            selectedStackIndex = -1;
          }
          applyPhotoStackLayout();
        }
      });

      card.addEventListener('blur', () => {
        if (hoveredStackIndex === index) {
          hoveredStackIndex = -1;

          if (selectedStackIndex === index) {
            selectedStackIndex = -1;
          }

          applyPhotoStackLayout();
        }
      });

      card.addEventListener('click', () => {
        selectedStackIndex = index;
        applyPhotoStackLayout();
        replaySignatureVideo();
      });
    });

    window.addEventListener('scroll', () => {
      if (getScrollY() <= TOP_RESET_THRESHOLD) {
        userHasScrolled = false;
      }

      scheduleBrandUpdate();
      updatePhotoStackSuction();
    }, { passive: true });
    window.addEventListener('resize', handleViewportChange);
    window.addEventListener('load', () => {
      measureBrand();
      measurePhotoStackSuction();
      revealHeroCopy();
      maybeAutoplaySignatureVideo();
    });
    window.addEventListener('pageshow', (event) => {
      measureBrand();
      measurePhotoStackSuction();
      revealHeroCopy();

      if (event.persisted) {
        replaySignatureVideo();
      }
    });
    window.addEventListener('touchmove', markUserScrollIntent, { passive: true });
    window.addEventListener('wheel', markUserScrollIntent, { passive: true });
    window.visualViewport?.addEventListener('resize', handleViewportChange);
    document.fonts?.ready?.then(() => {
      measureBrand();
      measurePhotoStackSuction();
    });
    signatureVideo?.addEventListener('loadeddata', maybeAutoplaySignatureVideo);
    window.setTimeout(() => {
      measureBrand();
      measurePhotoStackSuction();
    }, 180);
    applyPhotoStackLayout();
    measurePhotoStackSuction();
    measureBrand();
    revealHeroCopy();
  </script>
</body>
</html>
