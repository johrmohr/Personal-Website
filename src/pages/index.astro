  <script>
    document.getElementById('year').textContent = new Date().getFullYear().toString();
    const brand = document.querySelector('.brand--home');
    const introCopy = brand?.querySelector('.brand-intro-copy');
    const name = brand?.querySelector('.brand-name');
    const surnameMeasure = brand?.querySelector('.brand-measure--surname');
    let introWidth = 0;
    let nameWidth = 0;
    let surnameWidth = 0;
    let ticking = false;

    const updateBrand = () => {
      if (!brand) {
        return;
      }

      const scrollStart = window.innerWidth <= 768 ? 28 : 0;
      const progress = Math.max(0, Math.min(1, (window.scrollY - scrollStart) / 220));
      const collapsePoint = 0.58;
      const introProgress = Math.min(progress / collapsePoint, 1);
      const surnameProgress = progress <= collapsePoint
        ? 0
        : Math.min((progress - collapsePoint) / (1 - collapsePoint), 1);
      const currentIntroWidth = introWidth * (1 - introProgress);
      const introOpacity = 1 - introProgress;
      const introOffset = -Math.min(24, introWidth * 0.18) * introProgress;
      const currentSurnameWidth = surnameWidth * surnameProgress;
      const surnameOpacity = surnameProgress;
      const surnameShift = (1 - surnameProgress) * Math.min(24, surnameWidth * 0.18);
      const surnameGap = 6 * surnameProgress;
      const width = nameWidth + currentIntroWidth + surnameGap + currentSurnameWidth;

      brand.style.setProperty('--brand-progress', progress.toFixed(3));
      brand.style.setProperty('--brand-intro-width', `${currentIntroWidth}px`);
      brand.style.setProperty('--brand-intro-opacity', `${introOpacity.toFixed(3)}`);
      brand.style.setProperty('--brand-intro-offset', `${introOffset.toFixed(2)}px`);
      brand.style.setProperty('--brand-surname-width', `${currentSurnameWidth}px`);
      brand.style.setProperty('--brand-surname-opacity', `${surnameOpacity.toFixed(3)}`);
      brand.style.setProperty('--brand-surname-shift', `${surnameShift.toFixed(2)}px`);
      brand.style.setProperty('--brand-surname-gap', `${surnameGap.toFixed(2)}px`);
      brand.style.setProperty('--brand-width', `${width}px`);
      ticking = false;
    };

    const measureBrand = () => {
      if (!brand || !introCopy || !name || !surnameMeasure) {
        return;
      }

      introWidth = introCopy.getBoundingClientRect().width;
      nameWidth = name.getBoundingClientRect().width;
      surnameWidth = surnameMeasure.getBoundingClientRect().width;
      updateBrand();
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(updateBrand);
        ticking = true;
      }
    }, { passive: true });
    window.addEventListener('resize', measureBrand);
    window.addEventListener('load', measureBrand);
    document.fonts?.ready?.then(measureBrand);
    measureBrand();
  </script>
</body>
</html>
