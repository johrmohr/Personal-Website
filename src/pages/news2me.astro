---
import '../styles/site.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>News2me - Jordan Moreno</title>
  <link rel="icon" type="image/png" href="/Blackhole.png">
</head>
<body class="plain-page-body">
  <header class="site-header">
    <div class="site-header-leading">
      <a href="/" class="brand brand--static" aria-label="Jordan Moreno">Jordan Moreno</a>
    </div>
    <div class="site-header-trailing">
      <a href="/news2me" class="header-link" aria-current="page">News2me</a>
      <a href="/blog" class="header-link">Blog</a>
    </div>
  </header>

  <main class="plain-page">
    <section class="plain-page-content" aria-labelledby="news2me-title">
      <h1 id="news2me-title" class="plain-page-title">News2me</h1>
    </section>
  </main>

  <footer class="site-footer plain-page-footer">
    <span class="footer-copy">&copy; <span id="year"></span></span>
